# Configurazione Intents corretta
intents = nextcord.Intents.default()
intents.members = True
intents.message_content = True

bot = commands.Bot(intents=intents)

LOG_CHANNEL_STATUS = 1472932916362346551
GUILD_ID = 1472706575641870336 # <--- ASSICURATI CHE SIA IL TUO ID

async def get_guild_members(guild_id):
    guild = bot.get_guild(guild_id) or await bot.fetch_guild(guild_id)
    if not guild: return []
    members = await guild.fetch_members(limit=None)
    return [{
        "id": str(m.id),
        "name": m.display_name,
        "roles": [{"id": str(r.id), "name": r.name} for r in m.roles if r.name != "@everyone"]
    } for m in members]

async def modify_member_role(guild_id, member_id, role_id, action):
    guild = bot.get_guild(int(guild_id))
    member = await guild.fetch_member(int(member_id))
    role = guild.get_role(int(role_id))
    if action == "add": await member.add_roles(role)
    else: await member.remove_roles(role)

# Caricamento Cogs
for file in os.listdir("./cogs"):
    if file.endswith(".py") and file != "__init__.py":
        try:
            bot.load_extension(f"cogs.{file[:-3]}")
            print(f"Caricato: {file}")
        except Exception as e:
            print(f"Impossibile caricare {file}: {e}")

@bot.event
async def on_ready():
    # 1. Avvia il pannello in un thread separato per non bloccare il bot
    threading.Thread(target=lambda: start_panel(bot), daemon=True).start()
    
    print(f"✅ Ospedale San Camillo OPERATIVO")

    # 2. Invio Embed di stato nel canale Log
    channel = bot.get_channel(LOG_CHANNEL_STATUS)
    if channel:
        embed = nextcord.Embed(
            title="🏥 Sistema Ospedaliero Avviato",
            description="Il bot e la console di gestione sono ora online.",
            color=0x2ecc71,
            timestamp=datetime.now(timezone.utc)
        )
        embed.add_field(name="🌐 GUI Online", value="`http://localhost:5000`", inline=False)
        embed.add_field(name="⏰ Orario Avvio", value=f"<t:{int(datetime.now().timestamp())}:F>", inline=False)
        embed.set_footer(text="Ospedale San Camillo - Status System")
        await channel.send(embed=embed)

@asynccontextmanager
async def lifespan(app: FastAPI):
    await database.connect_db()
    db = database.get_db()
    await setup_bot(bot, db)
    yield
    await database.close_db()

app = FastAPI(
    title="Ospedale San Camillo",
    version="1.0.0",
    lifespan=lifespan,
    docs_url=None,
    redoc_url=None,
)

app.mount("/static", StaticFiles(directory="static"), name="static")
templates = Jinja2Templates(directory="templates")
app.include_router(auth_router)
app.include_router(dashboard_router)

@app.get("/", response_class=HTMLResponse)
async def index(request: Request):
    token = request.cookies.get("session_token")
    if token:
        return RedirectResponse("/dashboard")
    return templates.TemplateResponse("login.html", {"request": request})

async def run_bot():
    async with bot:
        await bot.start(config.DISCORD_BOT_TOKEN)

async def run_webserver():
    port = int(os.getenv("PORT", config.APP_PORT))
    server_config = uvicorn.Config(
        app=app,
        host=config.APP_HOST,
        port=port,
        log_level="info",
    )
    server = uvicorn.Server(server_config)
    await server.serve()

async def main():
    print("🚀 Avvio Ospedale San Camillo...")
    await asyncio.gather(
        run_bot(),
        run_webserver(),
    )

if __name__ == "__main__":
    asyncio.run(main())
